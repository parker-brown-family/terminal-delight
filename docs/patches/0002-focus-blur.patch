@@ -31,6 +41,18 @@ fn vs_crt(@builtin(vertex_index) vi: u32) -> CrtVsOut {
     return out;
 }
 
+// Signed distance to a rounded box, then a smoothstep feather across the edge.
+// Returns 1.0 fully INSIDE the panel, 0.0 fully OUTSIDE, smooth between — so the
+// sharp region follows the panel's rounded corners instead of a hard rectangle.
+fn panel_mask(p: vec2<f32>, rect: vec4<f32>, corner: f32, feather: f32) -> f32 {
+    let center = rect.xy + rect.zw * 0.5;
+    let half = rect.zw * 0.5;
+    let q = abs(p - center) - half + vec2<f32>(corner, corner);
+    let sdf = min(max(q.x, q.y), 0.0) + length(max(q, vec2<f32>(0.0))) - corner;
+    let f = max(feather, 1e-4);
+    return 1.0 - smoothstep(-f * 0.5, f * 0.5, sdf);
+}
