 @fragment
 fn fs_crt(in: CrtVsOut) -> @location(0) vec4<f32> {
     let dims = vec2<f32>(textureDimensions(screen_tex));
@@ -77,6 +99,47 @@ fn fs_crt(in: CrtVsOut) -> @location(0) vec4<f32> {
             return vec4<f32>(tube * inb, 1.0);
         }
     }
+
+    // ---- FOCUS frosted-glass backdrop (active while the reading modal is up) ----
+    let fb_radius = crt.focus_params.x;
+    if (fb_radius > 0.5) {
+        let sharp = textureSampleLevel(screen_tex, screen_samp, in.uv, 0.0);
+        let m = panel_mask(p, crt.focus_rect, crt.focus_params.w, crt.focus_params.y);
+        if (m > 0.999) {
+            // inside the panel: pristine, skip the blur taps entirely
+            return vec4<f32>(sharp.rgb, 1.0);
+        }
+        // Golden-angle (Vogel) disk blur with a per-pixel dither rotation. The
+        // spiral spreads samples evenly; rotating per pixel trades banding for
+        // fine dithered noise that the dim backdrop swallows — reads as smooth,
+        // creamy frosted glass rather than a cheap N-tap disk.
+        let TAPS = 32;
+        let GOLDEN = 2.3999632;
+        let ign = fract(52.9829189 * fract(dot(p, vec2<f32>(0.06711056, 0.00583715))));
+        let rot = ign * 6.2831853;
+        var acc = vec3<f32>(0.0);
+        var wsum = 0.0;
+        for (var t = 0; t < TAPS; t = t + 1) {
+            let ft = f32(t) + 0.5;
+            let rr = sqrt(ft / f32(TAPS));               // denser toward the centre
+            let ang = ft * GOLDEN + rot;
+            let off = vec2<f32>(cos(ang), sin(ang)) * rr * fb_radius;
+            let suv = clamp((p + off) / dims, vec2<f32>(0.0), vec2<f32>(1.0));
+            let w = exp(-rr * rr * 1.8);                 // gaussian-ish falloff
+            acc = acc + textureSampleLevel(screen_tex, screen_samp, suv, 0.0).rgb * w;
+            wsum = wsum + w;
+        }
+        var frost = acc / max(wsum, 1e-4);
+        // Frosted glass: a faint cool-white lift + a touch of extra depth-darken,
+        // both scaled by the tint knob, so the backdrop reads as glass, not just
+        // an out-of-focus photo.
+        let tint = crt.focus_params.z;
+        frost = mix(frost, vec3<f32>(0.80, 0.85, 0.93), 0.06 * tint);
+        frost = frost * (1.0 - 0.10 * tint);
+        // composite: sharp inside the panel, frosted outside, feathered across.
+        return vec4<f32>(mix(frost, sharp.rgb, m), 1.0);
+    }
+
     let col = textureSampleLevel(screen_tex, screen_samp, in.uv, 0.0);
     return vec4<f32>(col.rgb, col.a);
 }
