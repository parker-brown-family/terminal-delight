+// ---- terminal-delight FOCUS frosted-glass backdrop ----
+// While the 👓 reading modal is up, the panel rect (physical px) stays sharp and
+// everything outside it is blurred by the same CRT post-pass. Stored as
+// [x, y, w, h, blur_radius, feather, tint, corner_radius]; a radius <= 0.5
+// disables the effect (and gates the whole pass off when warp is also idle).
+static FOCUS_BLUR: std::sync::Mutex<[f32; 8]> = std::sync::Mutex::new([0.0; 8]);
+
+/// Set the FOCUS modal backdrop blur. `rect` is the panel (physical px) that
+/// stays sharp; everything outside it is frosted. `radius`/`feather`/`corner`
+/// are physical px, `tint` is 0..1. Pass radius <= 0.5 to disable.
+pub fn set_focus_blur(rect: [f32; 4], radius: f32, feather: f32, tint: f32, corner: f32) {
+    let mut g = FOCUS_BLUR.lock().unwrap();
+    *g = [
+        rect[0], rect[1], rect[2], rect[3], radius, feather, tint, corner,
+    ];
+}
+
+/// Returns (rect, radius, feather, tint, corner, active).
+fn focus_blur() -> ([f32; 4], f32, f32, f32, f32, bool) {
+    let g = FOCUS_BLUR.lock().unwrap();
+    let active = g[4] > 0.5;
+    ([g[0], g[1], g[2], g[3]], g[4], g[5], g[6], g[7], active)
+}
