@@ -0,0 +1,82 @@
+// terminal-delight CRT post-pass v2: PER-RECT barrel distortion.
+// The app registers up to 8 "tube" rectangles (terminal content areas, in
+// physical px). Pixels inside a rect warp in rect-local space; everything
+// else (bezel, buttons, chrome) passes through untouched, so hit-testing
+// stays exact. Curvature is PER RECT — each tube carries its own k1/k2 (in
+// glare.yz), so a pane on a bent theme bows even when the window theme is
+// flat, and a flat pane stays flat next to a bent neighbour. rects + glare
+// come from gpui_wgpu::set_crt_rects_tubes; k.z carries the rect count.
+
+struct CrtParams {
+    k: vec4<f32>,                  // global k1, k2 (gate only), rect_count, _pad
+    rects: array<vec4<f32>, 8>,    // x, y, w, h (physical px)
+    glare: array<vec4<f32>, 8>,    // strength, k1, k2, _pad (per-rect curvature)
+}
+
+@group(0) @binding(0) var<uniform> crt: CrtParams;
+@group(0) @binding(1) var screen_tex: texture_2d<f32>;
+@group(0) @binding(2) var screen_samp: sampler;
+
+struct CrtVsOut {
+    @builtin(position) pos: vec4<f32>,
+    @location(0) uv: vec2<f32>,
+}
+
+@vertex
+fn vs_crt(@builtin(vertex_index) vi: u32) -> CrtVsOut {
+    var out: CrtVsOut;
+    let xy = vec2<f32>(f32((vi << 1u) & 2u), f32(vi & 2u));
+    out.pos = vec4<f32>(xy * 2.0 - 1.0, 0.0, 1.0);
+    out.uv = vec2<f32>(xy.x, 1.0 - xy.y);
+    return out;
+}
+
+@fragment
+fn fs_crt(in: CrtVsOut) -> @location(0) vec4<f32> {
+    let dims = vec2<f32>(textureDimensions(screen_tex));
+    let p = in.uv * dims;
+    let n = u32(crt.k.z);
+    for (var i = 0u; i < n; i = i + 1u) {
+        let r = crt.rects[i];
+        if (p.x >= r.x && p.x < r.x + r.z && p.y >= r.y && p.y < r.y + r.w) {
+            // per-rect curvature: glare.y = k1, glare.z = k2. Each tube is
+            // authoritative for its own bend — a flat pane stays flat even when
+            // a bent neighbour has turned the pass on, and vice versa.
+            let k1 = crt.glare[i].y;
+            let k2 = crt.glare[i].z;
+            // a genuinely flat tube (a no-bend pane) passes straight through,
+            // so it looks identical with or without the pass — no vignette, no
+            // glare, exact hit-testing.
+            if (abs(k1) < 0.0005 && abs(k2) < 0.0005) {
+                return textureSampleLevel(screen_tex, screen_samp, in.uv, 0.0);
+            }
+            let local = (p - r.xy) / r.zw;
+            let c = local - vec2<f32>(0.5, 0.5);
+            let r2 = dot(c, c);
+            let f = 1.0 + k1 * r2 + k2 * r2 * r2;
+            let l2 = vec2<f32>(0.5, 0.5) + c * f;
+            let edge_distance = min(min(l2.x, 1.0 - l2.x), min(l2.y, 1.0 - l2.y));
+            let edge_width = max(max(fwidth(l2.x), fwidth(l2.y)) * 1.5, 1.0 / min(r.z, r.w));
+            let inb = smoothstep(-edge_width, edge_width, edge_distance);
+            let g = (r.xy + clamp(l2, vec2<f32>(0.0), vec2<f32>(1.0)) * r.zw) / dims;
+            let col = textureSampleLevel(screen_tex, screen_samp, g, 0.0);
+            let falloff = mix(0.86, 1.0, smoothstep(0.5, 0.12, r2));
+            let edge_blend = smoothstep(0.0, edge_width * 2.5, edge_distance);
+            let glare_strength = crt.glare[i].x;
+            let glare_offset = (local - vec2<f32>(0.18, 0.10)) / vec2<f32>(0.34, 0.18);
+            let glare_hotspot = exp(-dot(glare_offset, glare_offset) * 2.2);
+            let glare_band = (1.0 - smoothstep(0.0, 0.10, abs(local.y + local.x * 0.22 - 0.17)))
+                * (1.0 - smoothstep(0.0, 0.72, local.x))
+                * (1.0 - smoothstep(0.0, 0.42, local.y));
+            let glare_amount = clamp((glare_hotspot * 0.58 + glare_band * 0.34) * glare_strength, 0.0, 1.0);
+            let glare_color = vec3<f32>(0.72, 1.0, 0.78);
+            // sub-terminal phosphor runs +35% hotter than the raw sample so the
+            // warped tube doesn't read dim against flat chrome / flat panes.
+            let tube = mix(vec3<f32>(0.0), col.rgb * falloff * 1.35, edge_blend)
+                + glare_color * glare_amount;
+            return vec4<f32>(tube * inb, 1.0);
+        }
+    }
+    let col = textureSampleLevel(screen_tex, screen_samp, in.uv, 0.0);
+    return vec4<f32>(col.rgb, col.a);
+}
