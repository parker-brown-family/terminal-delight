+// ---- terminal-delight CRT warp (td-crt-pass patch) ----
+static CRT_K1: std::sync::atomic::AtomicU32 = std::sync::atomic::AtomicU32::new(0);
+static CRT_K2: std::sync::atomic::AtomicU32 = std::sync::atomic::AtomicU32::new(0);
+
+/// Set barrel-distortion coefficients for the post pass; (0, 0) disables it.
+pub fn set_crt_warp(k1: f32, k2: f32) {
+    CRT_K1.store(k1.to_bits(), std::sync::atomic::Ordering::Relaxed);
+    CRT_K2.store(k2.to_bits(), std::sync::atomic::Ordering::Relaxed);
+}
+
+fn crt_warp() -> (f32, f32) {
+    (
+        f32::from_bits(CRT_K1.load(std::sync::atomic::Ordering::Relaxed)),
+        f32::from_bits(CRT_K2.load(std::sync::atomic::Ordering::Relaxed)),
+    )
+}
+
+// (rect[x,y,w,h], glare, k1, k2) — curvature is per rect so each tube bends
+// on its own theme regardless of the window-wide dial.
+type CrtRect = ([f32; 4], f32, f32, f32);
+
+static CRT_RECTS: std::sync::Mutex<Vec<CrtRect>> = std::sync::Mutex::new(Vec::new());
+
+/// Replace the set of warped rectangles (physical px). Empty = pass disabled.
+pub fn set_crt_rects(rects: &[[f32; 4]]) {
+    let mut guard = CRT_RECTS.lock().unwrap();
+    guard.clear();
+    guard.extend(rects.iter().take(8).map(|rect| (*rect, 0.0, 0.0, 0.0)));
+}
+
+/// Replace the set of warped rectangles with a per-rect top-left glass glare.
+pub fn set_crt_rects_with_glare(rects: &[([f32; 4], f32)]) {
+    let mut guard = CRT_RECTS.lock().unwrap();
+    guard.clear();
+    guard.extend(
+        rects
+            .iter()
+            .take(8)
+            .map(|(rect, glare)| (*rect, glare.clamp(0.0, 1.0), 0.0, 0.0)),
+    );
+}
+
+/// Replace the set of warped rectangles with a per-rect glare AND per-rect
+/// barrel curvature (k1, k2). This is what the per-pane warp registry uses:
+/// each tube carries the curvature of its own theme.
+pub fn set_crt_rects_tubes(rects: &[([f32; 4], f32, f32, f32)]) {
+    let mut guard = CRT_RECTS.lock().unwrap();
+    guard.clear();
+    guard.extend(
+        rects
+            .iter()
+            .take(8)
+            .map(|(rect, glare, k1, k2)| (*rect, glare.clamp(0.0, 1.0), *k1, *k2)),
+    );
+}
+
+/// Returns (rects, packed glare+curvature [glare, k1, k2, _], count, max|k|).
+/// The max curvature magnitude lets the caller turn the pass on when any tube
+/// bends, even if the global dial is flat.
+fn crt_rects() -> ([[f32; 4]; 8], [[f32; 4]; 8], u32, f32) {
+    let guard = CRT_RECTS.lock().unwrap();
+    let mut rects = [[0.0f32; 4]; 8];
+    let mut glare = [[0.0f32; 4]; 8];
+    let mut max_k = 0.0f32;
+    for (i, (r, g, k1, k2)) in guard.iter().take(8).enumerate() {
+        rects[i] = *r;
+        glare[i] = [*g, *k1, *k2, 0.0];
+        max_k = max_k.max(k1.abs()).max(k2.abs());
+    }
+    (rects, glare, guard.len().min(8) as u32, max_k)
+}
+
+/// Lazily-built resources for the CRT post pass.
+struct CrtPass {
+    pipeline: wgpu::RenderPipeline,
+    layout: wgpu::BindGroupLayout,
+    sampler: wgpu::Sampler,
+    params_buffer: wgpu::Buffer,
+    texture: Option<wgpu::Texture>,
+}
+
+impl CrtPass {
+    fn new(device: &wgpu::Device, surface_format: wgpu::TextureFormat) -> Self {
+        let module = device.create_shader_module(wgpu::ShaderModuleDescriptor {
+            label: Some("crt_pass_shader"),
+            source: wgpu::ShaderSource::Wgsl(std::borrow::Cow::Borrowed(include_str!(
+                "crt_pass.wgsl"
+            ))),
+        });
+        let layout = device.create_bind_group_layout(&wgpu::BindGroupLayoutDescriptor {
+            label: Some("crt_pass_layout"),
+            entries: &[
+                wgpu::BindGroupLayoutEntry {
+                    binding: 0,
+                    visibility: wgpu::ShaderStages::FRAGMENT,
+                    ty: wgpu::BindingType::Buffer {
+                        ty: wgpu::BufferBindingType::Uniform,
+                        has_dynamic_offset: false,
+                        min_binding_size: None,
+                    },
+                    count: None,
+                },
+                wgpu::BindGroupLayoutEntry {
+                    binding: 1,
+                    visibility: wgpu::ShaderStages::FRAGMENT,
+                    ty: wgpu::BindingType::Texture {
+                        sample_type: wgpu::TextureSampleType::Float { filterable: true },
+                        view_dimension: wgpu::TextureViewDimension::D2,
+                        multisampled: false,
+                    },
+                    count: None,
+                },
+                wgpu::BindGroupLayoutEntry {
+                    binding: 2,
+                    visibility: wgpu::ShaderStages::FRAGMENT,
+                    ty: wgpu::BindingType::Sampler(wgpu::SamplerBindingType::Filtering),
+                    count: None,
+                },
+            ],
+        });
+        let pipeline_layout = device.create_pipeline_layout(&wgpu::PipelineLayoutDescriptor {
+            label: Some("crt_pass_pipeline_layout"),
+            bind_group_layouts: &[Some(&layout)],
+            immediate_size: 0,
+        });
+        let pipeline = device.create_render_pipeline(&wgpu::RenderPipelineDescriptor {
+            label: Some("crt_pass_pipeline"),
+            layout: Some(&pipeline_layout),
+            vertex: wgpu::VertexState {
+                module: &module,
+                entry_point: Some("vs_crt"),
+                buffers: &[],
+                compilation_options: wgpu::PipelineCompilationOptions::default(),
+            },
+            fragment: Some(wgpu::FragmentState {
+                module: &module,
+                entry_point: Some("fs_crt"),
+                targets: &[Some(wgpu::ColorTargetState {
+                    format: surface_format,
+                    blend: None,
+                    write_mask: wgpu::ColorWrites::ALL,
+                })],
+                compilation_options: wgpu::PipelineCompilationOptions::default(),
+            }),
+            primitive: wgpu::PrimitiveState {
+                topology: wgpu::PrimitiveTopology::TriangleList,
+                strip_index_format: None,
+                front_face: wgpu::FrontFace::Ccw,
+                cull_mode: None,
+                polygon_mode: wgpu::PolygonMode::Fill,
+                unclipped_depth: false,
+                conservative: false,
+            },
+            depth_stencil: None,
+            multisample: wgpu::MultisampleState::default(),
+            multiview_mask: None,
+            cache: None,
+        });
+        let sampler = device.create_sampler(&wgpu::SamplerDescriptor {
+            label: Some("crt_pass_sampler"),
+            address_mode_u: wgpu::AddressMode::ClampToEdge,
+            address_mode_v: wgpu::AddressMode::ClampToEdge,
+            mag_filter: wgpu::FilterMode::Linear,
+            min_filter: wgpu::FilterMode::Linear,
+            ..Default::default()
+        });
+        let params_buffer = device.create_buffer(&wgpu::BufferDescriptor {
+            label: Some("crt_pass_params"),
+            size: 16 + 8 * 16 + 8 * 16,
+            usage: wgpu::BufferUsages::UNIFORM | wgpu::BufferUsages::COPY_DST,
+            mapped_at_creation: false,
+        });
+        Self {
+            pipeline,
+            layout,
+            sampler,
+            params_buffer,
+            texture: None,
+        }
+    }
+
+    /// Surface-sized offscreen target the scene renders into when warp is on.
+    fn ensure_texture(
+        &mut self,
+        device: &wgpu::Device,
+        format: wgpu::TextureFormat,
+        width: u32,
+        height: u32,
+    ) {
+        let needs = match &self.texture {
+            Some(t) => t.width() != width.max(1) || t.height() != height.max(1),
+            None => true,
+        };
+        if needs {
+            self.texture = Some(device.create_texture(&wgpu::TextureDescriptor {
+                label: Some("crt_pass_scene"),
+                size: wgpu::Extent3d {
+                    width: width.max(1),
+                    height: height.max(1),
+                    depth_or_array_layers: 1,
+                },
+                mip_level_count: 1,
+                sample_count: 1,
+                dimension: wgpu::TextureDimension::D2,
+                format,
+                usage: wgpu::TextureUsages::RENDER_ATTACHMENT
+                    | wgpu::TextureUsages::TEXTURE_BINDING,
+                view_formats: &[],
+            }));
+        }
+    }
+}
+// ---- end td-crt-pass patch ----
+
