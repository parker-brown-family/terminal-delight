From 2a785e31a398e1e77c3a37739699c046bbf3852c Mon Sep 17 00:00:00 2001
From: Parker Brown <parker@brownfamilysports.com>
Date: Fri, 12 Jun 2026 15:39:58 -0700
Subject: [PATCH] td-crt-pass: barrel-distortion post pass for the wgpu
 renderer

---
 crates/gpui_wgpu/src/crt_pass.wgsl    |  44 +++++
 crates/gpui_wgpu/src/gpui_wgpu.rs     |   1 +
 crates/gpui_wgpu/src/wgpu_renderer.rs | 237 +++++++++++++++++++++++++-
 3 files changed, 280 insertions(+), 2 deletions(-)
 create mode 100644 crates/gpui_wgpu/src/crt_pass.wgsl

diff --git a/crates/gpui_wgpu/src/crt_pass.wgsl b/crates/gpui_wgpu/src/crt_pass.wgsl
new file mode 100644
index 0000000..bfe429a
--- /dev/null
+++ b/crates/gpui_wgpu/src/crt_pass.wgsl
@@ -0,0 +1,44 @@
+// terminal-delight CRT post-pass: barrel distortion over the finished frame.
+// The scene is rendered to an offscreen texture; this fullscreen pass samples
+// it with warped UVs so glyphs bow with the glass. k1/k2 come from the app
+// (gpui_wgpu::set_crt_warp), 0 disables the pass entirely upstream.
+
+struct CrtParams {
+    k1: f32,
+    k2: f32,
+    _pad0: f32,
+    _pad1: f32,
+}
+
+@group(0) @binding(0) var<uniform> crt: CrtParams;
+@group(0) @binding(1) var screen_tex: texture_2d<f32>;
+@group(0) @binding(2) var screen_samp: sampler;
+
+struct CrtVsOut {
+    @builtin(position) pos: vec4<f32>,
+    @location(0) uv: vec2<f32>,
+}
+
+@vertex
+fn vs_crt(@builtin(vertex_index) vi: u32) -> CrtVsOut {
+    // single fullscreen triangle
+    var out: CrtVsOut;
+    let xy = vec2<f32>(f32((vi << 1u) & 2u), f32(vi & 2u));
+    out.pos = vec4<f32>(xy * 2.0 - 1.0, 0.0, 1.0);
+    out.uv = vec2<f32>(xy.x, 1.0 - xy.y);
+    return out;
+}
+
+@fragment
+fn fs_crt(in: CrtVsOut) -> @location(0) vec4<f32> {
+    let c = in.uv - vec2<f32>(0.5, 0.5);
+    let r2 = dot(c, c);
+    let f = 1.0 + crt.k1 * r2 + crt.k2 * r2 * r2;
+    let uv = vec2<f32>(0.5, 0.5) + c * f;
+    let inb = step(0.0, uv.x) * step(uv.x, 1.0) * step(0.0, uv.y) * step(uv.y, 1.0);
+    var col = textureSampleLevel(screen_tex, screen_samp, clamp(uv, vec2<f32>(0.0), vec2<f32>(1.0)), 0.0);
+    // gentle brightness falloff with the curve, like a tube's corners
+    let falloff = mix(0.86, 1.0, smoothstep(0.5, 0.12, r2));
+    col = vec4<f32>(col.rgb * inb * falloff, 1.0);
+    return col;
+}
diff --git a/crates/gpui_wgpu/src/gpui_wgpu.rs b/crates/gpui_wgpu/src/gpui_wgpu.rs
index 452c3c0..a0eff57 100644
--- a/crates/gpui_wgpu/src/gpui_wgpu.rs
+++ b/crates/gpui_wgpu/src/gpui_wgpu.rs
@@ -7,4 +7,5 @@ pub use cosmic_text_system::*;
 pub use wgpu;
 pub use wgpu_atlas::*;
 pub use wgpu_context::*;
+pub use wgpu_renderer::set_crt_warp;
 pub use wgpu_renderer::{GpuContext, WgpuRenderer, WgpuSurfaceConfig};
diff --git a/crates/gpui_wgpu/src/wgpu_renderer.rs b/crates/gpui_wgpu/src/wgpu_renderer.rs
index 08f30dc..3535888 100644
--- a/crates/gpui_wgpu/src/wgpu_renderer.rs
+++ b/crates/gpui_wgpu/src/wgpu_renderer.rs
@@ -94,6 +94,165 @@ struct WgpuPipelines {
     surfaces: wgpu::RenderPipeline,
 }
 
+// ---- terminal-delight CRT warp (td-crt-pass patch) ----
+static CRT_K1: std::sync::atomic::AtomicU32 = std::sync::atomic::AtomicU32::new(0);
+static CRT_K2: std::sync::atomic::AtomicU32 = std::sync::atomic::AtomicU32::new(0);
+
+/// Set barrel-distortion coefficients for the post pass; (0, 0) disables it.
+pub fn set_crt_warp(k1: f32, k2: f32) {
+    CRT_K1.store(k1.to_bits(), std::sync::atomic::Ordering::Relaxed);
+    CRT_K2.store(k2.to_bits(), std::sync::atomic::Ordering::Relaxed);
+}
+
+fn crt_warp() -> (f32, f32) {
+    (
+        f32::from_bits(CRT_K1.load(std::sync::atomic::Ordering::Relaxed)),
+        f32::from_bits(CRT_K2.load(std::sync::atomic::Ordering::Relaxed)),
+    )
+}
+
+/// Lazily-built resources for the CRT post pass.
+struct CrtPass {
+    pipeline: wgpu::RenderPipeline,
+    layout: wgpu::BindGroupLayout,
+    sampler: wgpu::Sampler,
+    params_buffer: wgpu::Buffer,
+    texture: Option<wgpu::Texture>,
+}
+
+impl CrtPass {
+    fn new(device: &wgpu::Device, surface_format: wgpu::TextureFormat) -> Self {
+        let module = device.create_shader_module(wgpu::ShaderModuleDescriptor {
+            label: Some("crt_pass_shader"),
+            source: wgpu::ShaderSource::Wgsl(std::borrow::Cow::Borrowed(include_str!(
+                "crt_pass.wgsl"
+            ))),
+        });
+        let layout = device.create_bind_group_layout(&wgpu::BindGroupLayoutDescriptor {
+            label: Some("crt_pass_layout"),
+            entries: &[
+                wgpu::BindGroupLayoutEntry {
+                    binding: 0,
+                    visibility: wgpu::ShaderStages::FRAGMENT,
+                    ty: wgpu::BindingType::Buffer {
+                        ty: wgpu::BufferBindingType::Uniform,
+                        has_dynamic_offset: false,
+                        min_binding_size: None,
+                    },
+                    count: None,
+                },
+                wgpu::BindGroupLayoutEntry {
+                    binding: 1,
+                    visibility: wgpu::ShaderStages::FRAGMENT,
+                    ty: wgpu::BindingType::Texture {
+                        sample_type: wgpu::TextureSampleType::Float { filterable: true },
+                        view_dimension: wgpu::TextureViewDimension::D2,
+                        multisampled: false,
+                    },
+                    count: None,
+                },
+                wgpu::BindGroupLayoutEntry {
+                    binding: 2,
+                    visibility: wgpu::ShaderStages::FRAGMENT,
+                    ty: wgpu::BindingType::Sampler(wgpu::SamplerBindingType::Filtering),
+                    count: None,
+                },
+            ],
+        });
+        let pipeline_layout = device.create_pipeline_layout(&wgpu::PipelineLayoutDescriptor {
+            label: Some("crt_pass_pipeline_layout"),
+            bind_group_layouts: &[Some(&layout)],
+            immediate_size: 0,
+        });
+        let pipeline = device.create_render_pipeline(&wgpu::RenderPipelineDescriptor {
+            label: Some("crt_pass_pipeline"),
+            layout: Some(&pipeline_layout),
+            vertex: wgpu::VertexState {
+                module: &module,
+                entry_point: Some("vs_crt"),
+                buffers: &[],
+                compilation_options: wgpu::PipelineCompilationOptions::default(),
+            },
+            fragment: Some(wgpu::FragmentState {
+                module: &module,
+                entry_point: Some("fs_crt"),
+                targets: &[Some(wgpu::ColorTargetState {
+                    format: surface_format,
+                    blend: None,
+                    write_mask: wgpu::ColorWrites::ALL,
+                })],
+                compilation_options: wgpu::PipelineCompilationOptions::default(),
+            }),
+            primitive: wgpu::PrimitiveState {
+                topology: wgpu::PrimitiveTopology::TriangleList,
+                strip_index_format: None,
+                front_face: wgpu::FrontFace::Ccw,
+                cull_mode: None,
+                polygon_mode: wgpu::PolygonMode::Fill,
+                unclipped_depth: false,
+                conservative: false,
+            },
+            depth_stencil: None,
+            multisample: wgpu::MultisampleState::default(),
+            multiview_mask: None,
+            cache: None,
+        });
+        let sampler = device.create_sampler(&wgpu::SamplerDescriptor {
+            label: Some("crt_pass_sampler"),
+            address_mode_u: wgpu::AddressMode::ClampToEdge,
+            address_mode_v: wgpu::AddressMode::ClampToEdge,
+            mag_filter: wgpu::FilterMode::Linear,
+            min_filter: wgpu::FilterMode::Linear,
+            ..Default::default()
+        });
+        let params_buffer = device.create_buffer(&wgpu::BufferDescriptor {
+            label: Some("crt_pass_params"),
+            size: 16,
+            usage: wgpu::BufferUsages::UNIFORM | wgpu::BufferUsages::COPY_DST,
+            mapped_at_creation: false,
+        });
+        Self {
+            pipeline,
+            layout,
+            sampler,
+            params_buffer,
+            texture: None,
+        }
+    }
+
+    /// Surface-sized offscreen target the scene renders into when warp is on.
+    fn ensure_texture(
+        &mut self,
+        device: &wgpu::Device,
+        format: wgpu::TextureFormat,
+        width: u32,
+        height: u32,
+    ) {
+        let needs = match &self.texture {
+            Some(t) => t.width() != width.max(1) || t.height() != height.max(1),
+            None => true,
+        };
+        if needs {
+            self.texture = Some(device.create_texture(&wgpu::TextureDescriptor {
+                label: Some("crt_pass_scene"),
+                size: wgpu::Extent3d {
+                    width: width.max(1),
+                    height: height.max(1),
+                    depth_or_array_layers: 1,
+                },
+                mip_level_count: 1,
+                sample_count: 1,
+                dimension: wgpu::TextureDimension::D2,
+                format,
+                usage: wgpu::TextureUsages::RENDER_ATTACHMENT
+                    | wgpu::TextureUsages::TEXTURE_BINDING,
+                view_formats: &[],
+            }));
+        }
+    }
+}
+// ---- end td-crt-pass patch ----
+
 struct WgpuBindGroupLayouts {
     globals: wgpu::BindGroupLayout,
     instances: wgpu::BindGroupLayout,
@@ -158,6 +317,7 @@ pub struct WgpuRenderer {
     device_lost: std::sync::Arc<std::sync::atomic::AtomicBool>,
     surface_configured: bool,
     needs_redraw: bool,
+    crt: Option<CrtPass>,
 }
 
 impl WgpuRenderer {
@@ -488,6 +648,7 @@ impl WgpuRenderer {
             device_lost: context.device_lost_flag(),
             surface_configured: true,
             needs_redraw: false,
+            crt: None,
         })
     }
 
@@ -1151,6 +1312,28 @@ impl WgpuRenderer {
             .texture
             .create_view(&wgpu::TextureViewDescriptor::default());
 
+        // td-crt-pass: when warp is on, the scene renders offscreen and a
+        // final barrel-distortion pass writes the swapchain.
+        let (crt_k1, crt_k2) = crt_warp();
+        let crt_active = crt_k1.abs() > 0.0005 || crt_k2.abs() > 0.0005;
+        let crt_scene_view: Option<wgpu::TextureView> = if crt_active {
+            if self.crt.is_none() {
+                let pass = CrtPass::new(&self.resources().device, self.surface_config.format);
+                self.crt = Some(pass);
+            }
+            let (w, h) = (self.surface_config.width, self.surface_config.height);
+            let format = self.surface_config.format;
+            let device = self.resources().device.clone();
+            let crt = self.crt.as_mut().unwrap();
+            crt.ensure_texture(&device, format, w, h);
+            crt.texture
+                .as_ref()
+                .map(|t| t.create_view(&wgpu::TextureViewDescriptor::default()))
+        } else {
+            None
+        };
+        let scene_target: &wgpu::TextureView = crt_scene_view.as_ref().unwrap_or(&frame_view);
+
         let gamma_params = GammaParams {
             gamma_ratios: self.rendering_params.gamma_ratios,
             grayscale_enhanced_contrast: self.rendering_params.grayscale_enhanced_contrast,
@@ -1213,7 +1396,7 @@ impl WgpuRenderer {
                 let mut pass = encoder.begin_render_pass(&wgpu::RenderPassDescriptor {
                     label: Some("main_pass"),
                     color_attachments: &[Some(wgpu::RenderPassColorAttachment {
-                        view: &frame_view,
+                        view: scene_target,
                         resolve_target: None,
                         ops: wgpu::Operations {
                             load: wgpu::LoadOp::Clear(wgpu::Color::TRANSPARENT),
@@ -1252,7 +1435,7 @@ impl WgpuRenderer {
                             pass = encoder.begin_render_pass(&wgpu::RenderPassDescriptor {
                                 label: Some("main_pass_continued"),
                                 color_attachments: &[Some(wgpu::RenderPassColorAttachment {
-                                    view: &frame_view,
+                                    view: scene_target,
                                     resolve_target: None,
                                     ops: wgpu::Operations {
                                         load: wgpu::LoadOp::Load,
@@ -1327,6 +1510,56 @@ impl WgpuRenderer {
                 continue;
             }
 
+            // td-crt-pass: warp the offscreen scene onto the swapchain
+            if let (true, Some(scene_view)) = (crt_active, crt_scene_view.as_ref()) {
+                if let Some(crt) = self.crt.as_ref() {
+                    let resources = self.resources();
+                    resources.queue.write_buffer(
+                        &crt.params_buffer,
+                        0,
+                        bytemuck::bytes_of(&[crt_k1, crt_k2, 0.0f32, 0.0f32]),
+                    );
+                    let bind_group =
+                        resources
+                            .device
+                            .create_bind_group(&wgpu::BindGroupDescriptor {
+                                label: Some("crt_pass_bind_group"),
+                                layout: &crt.layout,
+                                entries: &[
+                                    wgpu::BindGroupEntry {
+                                        binding: 0,
+                                        resource: crt.params_buffer.as_entire_binding(),
+                                    },
+                                    wgpu::BindGroupEntry {
+                                        binding: 1,
+                                        resource: wgpu::BindingResource::TextureView(scene_view),
+                                    },
+                                    wgpu::BindGroupEntry {
+                                        binding: 2,
+                                        resource: wgpu::BindingResource::Sampler(&crt.sampler),
+                                    },
+                                ],
+                            });
+                    let mut pass = encoder.begin_render_pass(&wgpu::RenderPassDescriptor {
+                        label: Some("crt_pass"),
+                        color_attachments: &[Some(wgpu::RenderPassColorAttachment {
+                            view: &frame_view,
+                            resolve_target: None,
+                            ops: wgpu::Operations {
+                                load: wgpu::LoadOp::Clear(wgpu::Color::BLACK),
+                                store: wgpu::StoreOp::Store,
+                            },
+                            depth_slice: None,
+                        })],
+                        depth_stencil_attachment: None,
+                        ..Default::default()
+                    });
+                    pass.set_pipeline(&crt.pipeline);
+                    pass.set_bind_group(0, &bind_group, &[]);
+                    pass.draw(0..3, 0..1);
+                }
+            }
+
             self.resources()
                 .queue
                 .submit(std::iter::once(encoder.finish()));
